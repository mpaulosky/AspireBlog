@using AspireBlog.Abstractions.Entities
@using AspireBlog.Data.Mongo.Repositories
@inject IUnitOfWork UnitOfWork

<h3>Categories</h3>
<hr/>
<ul class="list-unstyled">
	@foreach (var category in _categories)
	{
		var categoryPostsLink = $"/c/{category.Slug}/posts";
		<li class="mb-1 border-bottom p-1">
			<NavLink href="@categoryPostsLink" class="text-decoration-none fs-6 py-2">@category.CategoryName</NavLink>
		</li>
	}
</ul>

@code {
	[Parameter] public string? CategorySlug { get; set; }

	[Parameter] public EventCallback<string> OnCategoryNameFound { get; set; }

	private IEnumerable<Category> _categories = [];

	private string? _prevSlug;

	protected override async Task OnParametersSetAsync()
	{
		if (_prevSlug != CategorySlug)
		{
			await SetCategoryNameAsync();
		}

		_prevSlug = CategorySlug;
	}

	private async Task LoadCategoriesAsync()
	{
		if (!_categories.Any())
		{
			_categories = await UnitOfWork.Category.GetAllAsync();
		}
	}

	protected override async Task OnInitializedAsync()
	{
		await LoadCategoriesAsync();
	}

	private async Task SetCategoryNameAsync()
	{
		if (!string.IsNullOrWhiteSpace(CategorySlug))
		{
			var categoryName = _categories.First(c => c.Slug == CategorySlug).CategoryName;
			await OnCategoryNameFound.InvokeAsync(categoryName);
		}
	}

}